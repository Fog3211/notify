# ============================================================
# 复制为 .env 并填入真实值；.env 已被 .gitignore 忽略，不会入库。
# 只需填你实际启用的 provider / 渠道对应的变量。
# ============================================================

# ---------- LLM provider 密钥（按 config.yaml 里 llm.provider 选用，只填用到的）----------
# 免费档（白嫖首选）：
#   Groq   https://console.groq.com 免费额度、超快，跑开源大模型
GROQ_API_KEY=
#   Gemini https://aistudio.google.com/apikey 免费额度（Flash 系列够用）
GEMINI_API_KEY=
# 低价 / 付费：
#   DeepSeek（OpenAI 兼容，便宜）
DEEPSEEK_API_KEY=
#   Anthropic Claude
ANTHROPIC_API_KEY=
#   OpenAI
OPENAI_API_KEY=
#   通义千问 / 其他 OpenAI 兼容服务
DASHSCOPE_API_KEY=

# ---------- 数据源 API 密钥（可选，不填则只用免费 RSS）----------
# https://finnhub.io 免费额度，用于股票新闻/行情
FINNHUB_API_KEY=
# https://www.alphavantage.co 免费额度
ALPHAVANTAGE_API_KEY=
# https://newsapi.org 免费额度
NEWSAPI_API_KEY=

# ---------- 推送渠道 ----------
# 微信：PushPlus（http://www.pushplus.plus）token
PUSHPLUS_TOKEN=
# 微信：Server酱（https://sct.ftqq.com）SendKey，形如 SCTxxxx
SERVERCHAN_SENDKEY=
# 飞书自定义机器人 webhook 完整 URL
FEISHU_WEBHOOK_URL=
# 飞书机器人加签密钥（若机器人开启了「签名校验」才需要）
FEISHU_WEBHOOK_SECRET=
